APP_JWT_SECRET=super-secret-jwt-key-that-is-at-least-32-bytes-long
APP_JWT_COOKIE_SECURE=true
APP_GOOGLE_BOOKS_API_KEY=
APP_DISCOVERY_PROVIDER=google-books
DB_USERNAME=postgres

# Copy this file to `.env` before running:
# docker compose -f docker-compose.prod.yml up -d --build

# --- Backend security ---
# Generate a strong secret, for example:
# openssl rand -base64 32
APP_JWT_SECRET=replace-with-a-strong-random-secret

# --- Database ---
DB_USERNAME=readwick
DB_PASSWORD=replace-with-a-strong-db-password

# --- CORS ---
# Public origin used by browsers to access the frontend.
APP_CORS_ORIGINS=https://readwick.example.com
